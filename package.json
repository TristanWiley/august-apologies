{
  "name": "august-apology",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:twitch": "vite --config extensions/twitch/vite.config.ts",
    "build": "vite build",
    "build:twitch": "vite build --config extensions/twitch/vite.config.ts",
    "openapi-fetch": "curl -X GET http://localhost:5173/api/openapi.json -o src/api/openapi.json",
    "gen:client": "pnpm openapi-fetch && pnx openapi-typescript src/api/openapi.json -o ./src/api/schema.ts",
    "spotify:openapi-fetch": "curl -X GET https://developer.spotify.com/reference/web-api/open-api-schema.yaml -o api/spotify/spotify-openapi.yaml",
    "spotify:gen:client": "pnpm spotify:openapi-fetch && pnx openapi-typescript api/spotify/spotify-openapi.yaml -o ./api/spotify/spotify-schema.ts",
    "preview": "pnpm run build && vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "lint": "eslint ."
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tristanwiley/spotify-web-api-ts-sdk": "github:TristanWiley/spotify-web-api-ts-sdk",
    "@types/twitch-ext": "^1.24.9",
    "chanfana": "^3.3.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.12.2",
    "itty-router": "^5.0.23",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-dvd-screensaver": "^0.1.2",
    "react-router": "^7.14.2",
    "react-simple-wysiwyg": "^3.4.1",
    "sanitize-html": "^2.17.3",
    "tailwindcss": "^4.2.4",
    "ts-twitch-api": "^0.2.8",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.35.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/twitch-browser": "^1.0.4",
    "@vitejs/plugin-react": "^6.0.1",
    "baseline-browser-mapping": "^2.10.25",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.12",
    "wrangler": "^4.90.1"
  }
}
